# Multi-source mode is now always on inside /api/live-scores.js.
# The endpoint fetches enabled free APIs and web scrape sources simultaneously.

# Free no-key ESPN JSON API source.
ENABLE_ESPN_API=true
ESPN_SCOREBOARD_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard

# Optional ESPN date filter, e.g. 20260614.
# ESPN_DATES=20260614

# Provider timeout in milliseconds.
PROVIDER_TIMEOUT_MS=7000

# Server-side web scraping source.
ENABLE_ESPN_SCRAPE=true
ESPN_SCRAPE_URL=https://www.espn.com/soccer/scoreboard/_/league/fifa.world

# Optional official FIFA web page scraping.
# Disabled by default because modern FIFA pages can be heavily client-rendered.
ENABLE_FIFA_SCRAPE=false
FIFA_SCRAPE_URL=https://www.fifa.com/en/tournaments/mens/worldcup/canadamexicousa2026/scores-fixtures

# Optional community/open-source World Cup source.
ENABLE_WORLDCUP26_FREE=false
WORLDCUP26_GAMES_URL=https://worldcup26.ir/get/games
WORLDCUP26_GROUPS_URL=https://worldcup26.ir/get/groups
WORLDCUP26_TEAMS_URL=https://worldcup26.ir/get/teams

# Optional API-Football/API-Sports mode. Only runs if APISPORTS_KEY exists.
ENABLE_API_FOOTBALL=true
APISPORTS_KEY=
APISPORTS_LEAGUE=1
APISPORTS_SEASON=2026

# Optional custom realtime JSON feed.
ENABLE_JSON_FEED=true
JSON_FEED_URL=

# Optional display labels only. These are not mock scores.
EVENT_NAME=Your real event name
PUBLIC_NOTICE=Your real public venue notice
VENUE_LABEL=Your real venue zone
VENUE_DETAIL=Your real venue status message
VENUE_CAPACITY=0
SPONSORS=Real Sponsor 1,Real Sponsor 2,Real Sponsor 3
